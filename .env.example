# ============================================================
# PowerBI Genius AI — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ---- AI Keys (Required) ----
OPENAI_API_KEY=sk-...                    # Required for GPT-4o agents
ANTHROPIC_API_KEY=sk-ant-...             # Optional: for Claude fallback

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Power BI Embedded (Optional — for real PBIX generation) ----
POWERBI_CLIENT_ID=                       # Azure App Client ID
POWERBI_CLIENT_SECRET=                   # Azure App Secret
POWERBI_TENANT_ID=                       # Azure Tenant ID
POWERBI_WORKSPACE_ID=                    # Power BI Workspace GUID

# ---- Azure Storage (Optional — for large file uploads) ----
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=uploads

# ---- Database (Optional — for persistent job storage) ----
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://user:pass@localhost:5432/powerbi_genius

# ---- Kaggle (Optional — for Kaggle dataset downloads) ----
KAGGLE_USERNAME=
KAGGLE_KEY=
